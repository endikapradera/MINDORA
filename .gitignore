# ─── Models (large files, download separately) ────────────────────────────
*.gguf
models/
data/

# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.Python
pip-log.txt

# ─── PyInstaller build artifacts (generated on each build, NOT source) ────
core/dist/
core/build/

# ─── Embedding model (downloaded automatically during build) ─────────────
core/assets/embedding_model/

# ─── Node ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── Tauri / Rust build outputs ───────────────────────────────────────────
ui/dist/
ui/src-tauri/target/

# ─── macOS system files ───────────────────────────────────────────────────
.DS_Store
**/.DS_Store
*.pages.lock
